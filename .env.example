# MIA environment template
#
# Defaults below match the included Docker Compose stack:
# - frontend -> http://localhost:3313
# - backend  -> http://localhost:8080 (host) / http://backend:8080 (inside Docker)
# - postgres -> postgres:5432
# - redis    -> redis:6379
#
# You must provide your own BNB websocket RPC, LLM endpoint, and Moralis API key.

# ── Runtime / App URLs ────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3313
APP_ALLOWED_ORIGINS=http://localhost:3313,http://127.0.0.1:3313
NEXT_PUBLIC_API_URL=/api/backend
INTERNAL_API_URL=http://backend:8080

# ── Database / Cache ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://mia:mia_password@postgres:5432/mia_db
REDIS_URL=redis://redis:6379

# Host-mode examples:
# DATABASE_URL=postgres://mia:mia_password@localhost:5432/mia_db
# REDIS_URL=redis://localhost:6379
# INTERNAL_API_URL=http://127.0.0.1:8080

# ── Server / Logging ──────────────────────────────────────────────────────────
SERVER_PORT=8080
LOG_LEVEL=info
RUST_LOG=info

# ── BNB Chain indexer ─────────────────────────────────────────────────────────
# Required primary websocket RPC.
BNB_RPC_WS_URL=wss://your-primary-bsc-ws-endpoint.example/ws
# Optional additional private RPCs (comma-separated).
BNB_RPC_WS_URLS=
# Optional public fallbacks (comma-separated). Leave empty to use built-in defaults.
BNB_RPC_PUBLIC_WS_URLS=
# Four.Meme factory contract on BSC mainnet.
FOUR_MEME_CONTRACT_ADDRESS=0x5c952063c7fc8610FFDB798152D69F0B9550762b
# Keep false unless you explicitly want a startup deployment backfill.
INDEXER_DEPLOYMENT_BACKFILL_ENABLED=false

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Use any OpenAI-compatible endpoint: OpenAI, OpenRouter, local proxy, or your own gateway.
LLM_API_URL=https://your-openai-compatible-endpoint.example/v1
LLM_API_KEY=replace-with-your-llm-api-key
LLM_MODELS=gpt-5.4,gpt-5.2,gpt-5.4-mini
AI_CACHE_TTL_SECS=300
AI_BUY_THRESHOLD=10
AI_THRESHOLD_WINDOW_SECS=600
# Only score tokens with enough activity to justify LLM cost.
AI_SCORE_MIN_TX_COUNT=50
# Automatically queue Deep Research for high-activity tokens.
AUTO_DEEP_RESEARCH_TX_THRESHOLD=500

# ── Monitoring / investigation loop ───────────────────────────────────────────
WHALE_ALERT_THRESHOLD_BNB=0.5
ALPHA_REFRESH_SECS=3600
ALPHA_TOP_K=10
AUTO_INVESTIGATION_ENABLED=true
AUTO_INVESTIGATION_INTERVAL_SECS=300
AUTO_INVESTIGATION_TX_THRESHOLD=100
AUTO_INVESTIGATION_COOLDOWN_MINS=240
AUTO_INVESTIGATION_MAX_RUNS_PER_SCAN=3
INVESTIGATION_FIXTURE_API_ENABLED=false

# ── ML rollout controls ───────────────────────────────────────────────────────
# legacy | shadow | ml | hybrid
ML_ROLLOUT_MODE=shadow
ML_MODEL_VERSION=lightgbm-shadow-v0
ML_MIN_CONFIDENCE=0.55

# ── Holder / contract enrichment ──────────────────────────────────────────────
# Moralis is the primary holder enrichment path for active tokens.
MORALIS_API_KEY=
MORALIS_API_URL=https://deep-index.moralis.io/api/v2.2
# Optional explorer metadata fallback.
BSCSCAN_API_KEY=
BSCSCAN_API_URL=https://api.etherscan.io/v2/api
BSCSCAN_CHAIN_ID=56

# ── Deep Research / Ask MIA ───────────────────────────────────────────────────
DEEP_RESEARCH_ENABLED=false
ASK_MIA_FUNCTION_CALLING_ENABLED=false
# heurist_mesh_x402 | native_x_api
DEEP_RESEARCH_PROVIDER=heurist_mesh_x402
# unlock_this_report | day_pass
DEEP_RESEARCH_UNLOCK_MODEL=unlock_this_report

# ── x402 payments / premium unlocks ───────────────────────────────────────────
X402_ENABLED=false
X402_FACILITATOR_URL=https://facilitator.bankofai.io
X402_FACILITATOR_API_KEY=
X402_PAY_TO=
X402_ASSET_ADDRESS=
X402_FACILITATOR_ID=
X402_FEE_TO=
X402_CALLER=
X402_FEE_AMOUNT=0
X402_NETWORK=eip155:56
X402_SCHEME=exact_permit
X402_PRICE_USDC_CENTS=50
X402_MAX_TIMEOUT_SECS=60

# ── Heurist Mesh / paid research provider ─────────────────────────────────────
HEURIST_MESH_API_URL=https://mesh.heurist.xyz
HEURIST_MESH_AGENT_SET=deep_research
HEURIST_API_KEY=
HEURIST_X402_WALLET_DIR=
HEURIST_X402_WALLET_ID=mia-base-upstream
HEURIST_X402_WALLET_PASSWORD=

# ── Optional outbound integrations ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
